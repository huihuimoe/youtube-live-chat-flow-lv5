{
  "compilerOptions": {
    "target": "ES2023",
    "module": "esnext",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "sourceMap": true,
    "paths": {
      "~/*": ["./src/*"],
      "~~/*": ["./*"]
    },
    "types": ["chrome"],
    "strict": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src", "manifest.config.ts", "vite.config.ts"]
}
