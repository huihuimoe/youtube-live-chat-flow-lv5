{
  "name": "youtube-live-chat-flow",
  "version": "0.1.3",
  "private": true,
  "description": "Chrome Extension for Flow Chat Messages on YouTube Live.",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "format": "oxfmt --write",
    "lint": "pnpm lint:oxlint && pnpm lint:oxfmt",
    "lint:oxfmt": "oxfmt --check",
    "lint:oxlint": "oxlint --type-aware --type-check",
    "package": "pnpm build && mkdir -p dist && zip -r dist/archive.zip app",
    "prepare": "husky",
    "test": "pnpm lint && pnpm typecheck && pnpm build",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@fiahfy/semaphore": "^0.0.2",
    "color": "^5.0.3",
    "vue": "2.7.14",
    "vuetify": "2.6.14",
    "vuex": "3.6.2",
    "vuex-module-decorators": "1.2.0",
    "vuex-persist": "3.1.3"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@types/chrome": "^0.1.43",
    "@types/node": "^25.9.2",
    "@typescript/native-preview": "beta",
    "@vitejs/plugin-vue2": "^2.3.4",
    "husky": "^9.1.7",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "oxlint-tsgolint": "^0.23.0",
    "vite": "^7.3.5",
    "vue-template-compiler": "2.7.14"
  },
  "engines": {
    "node": ">=22.13"
  },
  "packageManager": "pnpm@11.5.2",
  "productName": "Flow Chat for YouTube Live"
}
