{
  "name": "youtube-live-chat-flow",
  "version": "0.1.3",
  "private": true,
  "description": "Chrome Extension for Flow Chat Messages on YouTube Live.",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "format": "oxfmt --write",
    "lint": "pnpm lint:oxlint && pnpm lint:oxfmt",
    "lint:oxfmt": "oxfmt --check",
    "lint:oxlint": "oxlint --type-aware --type-check",
    "package": "pnpm build && mkdir -p dist && zip -r dist/archive.zip app",
    "prepare": "husky",
    "test": "pnpm lint && pnpm typecheck && pnpm unit && pnpm build",
    "unit": "vitest run",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "color": "^5.0.3",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.35",
    "vuetify": "^4.1.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@types/chrome": "^0.1.43",
    "@types/node": "^25.9.2",
    "@typescript/native-preview": "beta",
    "@vitejs/plugin-vue": "^6.0.7",
    "happy-dom": "^20.10.2",
    "husky": "^9.1.7",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "oxlint-tsgolint": "^0.23.0",
    "vite": "^8.0.16",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22.13"
  },
  "packageManager": "pnpm@11.5.2",
  "productName": "Flow Chat for YouTube Live"
}
